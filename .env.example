# A.E.G.I.S Environment Configuration

# Backend configuration
PORT=8000
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY_FOR_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Configuration (Local Ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Speech configuration
# If Piper TTS is installed via pip/cli, specify the executable and model paths
PIPER_PATH=piper
PIPER_MODEL=en_US-lessac-medium.onnx
